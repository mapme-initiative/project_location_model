{
  "name": "ogm-validator-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "copy-schemas": "mkdir -p public/schemas && cp ../model/schema/feature_project_schema.json ../model/schema/project_core_schema_*.json public/schemas/",
    "dev": "npm run copy-schemas && vite --mode development",
    "build": "npm run copy-schemas && tsc -b && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "jest"
  },
  "jest": {
    "coverageReporters": [
      "text",
      "json-summary",
      "json"
    ],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@mui/styled-engine-sc": "^7.0.0",
    "@placemarkio/tokml": "^0.3.4",
    "@types/file-saver": "^2.0.7",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "exceljs": "^4.4.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsonc-parser": "^3.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "5.0.0",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^14.2.1",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^30.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.fullscreen": "^3.0.2",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.3.16",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "file-saver": "^2.0.5",
    "gh-pages": "^6.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "leaflet": "^1.9.4",
    "leaflet.fullscreen": "^3.0.2",
    "papaparse": "^5.5.3",
    "react-router-dom": "^7.7.0",
    "sass": "^1.99.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-eslint": "^1.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
