    },
    "geographic_exactness": {
      "description": "Use 'exact' if the exact coordinates are known + no security restrictions apply. Otherwise, use 'approximate (security)' or 'approx. (yet unknown)'. If the target area is an admin unit, use 'approx. (admin unit).'.",
      "enum": [
        "exact",
        "approximate (yet unknown)",
        "approximate (security)",
        "approximate (admin unit)"
      ],
      "type": "string"
    },
    "latitude": {
      "description": "Optional. Provide this value only when uploading coordinates via Excel",
      "type": "number"
    },
    "longitude": {
      "description": "Optional. Provide this value only when uploading coordinates via Excel",
      "type": "number"
    }
  },
  "required": [
    "scheme_version",
    "donor_project_no",
    "project_acronym",
    "data_provider",
    "publishing_restrictions",
    "date_of_data_collection",
    "related_community",
    "location_name",
    "location_activity_status",
    "activity_start_date",
    "activity_end_date",
    "activity_description",
    "location_type_theme",
    "location_type_name",
    "geographic_exactness"
